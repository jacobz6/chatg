# chapter2.rpy — 第二章：账目迷局
# ============================================================

label chapter2_start:
    jump chapter2

label chapter2:
    # 全局变量安全初始化
    python:
        for var_name in ['responsibility', 'empathy', 'insight', 'resilience', 'integrity']:
            if var_name not in globals():
                globals()[var_name] = 5

    # 本章增量追踪变量
    $ ch2_integrity_delta = 0
    $ ch2_insight_delta = 0
    $ ch2_empathy_delta = 0
    $ ch2_resilience_delta = 0

    # 重置本章变量
    $ ch2_choice_record = []
    $ ch2_found_suspicious = False
    $ ch2_reported_to_sun = False
    $ ch2_investigating = False
    $ ch2_liu_jie_info = False
    $ ch2_zhang_wenhao_resigned = False
    $ ch2_tianyancha_checked = False
    $ ch2_finance_checked = False

    scene black with fade
    pause 0.5

    # 章节标题
    show text "第二章：账目迷局" with dissolve
    pause 2
    hide text with dissolve

    # ============================================================
    # 场景1：办公室 · 清晨
    # ============================================================
    scene bg_office_morning with fade

    narrator "六月的广州，酷暑难耐。"
    narrator "研究生院办公室的空调呼呼地吹着冷风，但沈思的额头上还是渗出了细密的汗珠。"
    narrator "桌上堆满了各种报销单据，像一座小山。"

    narrator "这是暑假前最后一周——也是财务处最忙的时候。"
    narrator "研究生院的报销单据从四面八方涌来：课题经费、会议差旅、设备采购、论文版面费……每一笔都需要她初审，然后交给财务处复审。"

    narrator "沈思已经连续加班一周了。昨晚她整理账目到凌晨一点，今天早上七点半就到了办公室。"
    narrator "窗外的木棉树在晨风中轻轻摇曳，远处传来早起的鸟鸣。"

    narrator "她泡了杯菊花茶，放在手边。杯中的菊花在热水的冲泡下慢慢舒展开来，像是在告诉她——放慢节奏，别太着急。"

    narrator "但她没法不急。"

    narrator "桌上有一份文件，封面写着「研究生院2026年度上半年财务审计报告（草稿）」，她已经看了三遍。每一遍，都让她心惊肉跳。"

    # ============================================================
    # 1.1 日常工作的繁琐
    # ============================================================
    narrator "沈思坐在工位上，手里握着一支黑色签字笔，面前摊开着一叠厚厚的报销单据。"
    narrator "她的工位在研究生院办公室最靠里的位置，紧挨着窗户，正对着行政楼后面的小花园。"
    narrator "此刻，阳光透过百叶窗的缝隙，在她的桌面上投下一道道明暗相间的条纹。"

    narrator "她看了看墙上的挂钟——八点十五分。距离正式上班还有十五分钟，但办公室里已经有人了。"
    narrator "张姐坐在她对面的工位上，正低头整理着一摞文件，手指在键盘上飞快地敲击着。"

    show zhang_jie at left with dissolve

    zhang_jie "（头也不抬）小沈，来得挺早啊。"

    shen_si "（笑了笑）没办法，这周要审的单子太多了，不早点来根本审不完。"

    zhang_jie "（叹了口气）是啊，每年暑假前都这样。各个课题组都跟疯了似的，赶着在放假前把经费花完。你那边助研津贴的审核进度怎么样了？"

    shen_si "（翻了翻桌上的文件）还差十几份吧。主要是有些课题组的材料不齐全，退回去让他们补，一来一回就耽误时间了。"

    zhang_jie "（摇了摇头）这些导师啊，一个个都是教授、博导，连基本的报销规范都搞不清楚。你说他们做科研那么厉害，怎么填个表格就这么费劲呢？"

    shen_si "（笑了笑）可能他们觉得这种事太琐碎了吧。毕竟人家是搞学术的，看不上这些行政事务。"

    zhang_jie "（撇了撇嘴）看不上？那别报销啊。既要拿钱，又不想按规定来，哪有这么好的事？"

    narrator "沈思没有接话，只是低头继续审她的单子。她知道张姐说得对，但她也知道，在这个体制里，有些事情不是对错那么简单。"

    narrator "她拿起一份报销单，开始逐项核对。"

    narrator "助研津贴的审核流程，她已经做了三年，闭着眼睛都能背出来——"
    narrator "第一步，核对发放名单——确认每个领取津贴的学生确实在该课题组注册，且学籍状态正常。"
    narrator "第二步，核对发放标准——硕士每月2000元，博士每月3000元，不能超过这个标准。"
    narrator "第三步，核对发放周期——一般按学期发放，每学期发放5个月，寒暑假不发。"
    narrator "第四步，核对签字盖章——需要导师签字、学院盖章、研究生院审核。"
    narrator "第五步，核对附件材料——包括学生的银行卡复印件、身份证复印件、助研协议等。"

    narrator "这五个步骤，每一步都不能出错。一旦出错，轻则退回去重新补材料，重则引发财务纠纷，甚至审计问题。"

    narrator "沈思深吸一口气，开始审第一份单子。"
    narrator "这是一份来自机械与汽车工程学院的助研津贴发放表，导师是李建国教授，发放对象是5名硕士研究生，每人每月2000元，发放周期是2026年3月至7月，共计5个月，总金额50000元。"

    narrator "沈思逐项核对——发放名单、发放标准、发放周期、签字盖章、附件材料，一应俱全。"

    narrator "没问题。"

    narrator "沈思在审核人一栏签下自己的名字，然后在电脑上录入审核结果，点击「通过」。"

    narrator "她拿起第二份单子，开始重复同样的流程。"

    narrator "一上午的时间，就在这种机械的重复中悄然流逝。沈思审完了8份单子，其中有6份通过，2份因为材料不齐全被退回。"

    narrator "她揉了揉发酸的眼睛，看了看墙上的挂钟——十一点四十五分。还有十五分钟就要下班了，但她还有4份单子没审完。"

    zhang_jie "（站起身，伸了个懒腰）小沈，吃饭去不？"

    shen_si "（摇了摇头）你先去吧，我把这几份审完再说。"

    zhang_jie "（叹了口气）你也别太拼了，身体是自己的。走吧，一起去，吃完再回来审。"

    shen_si "（犹豫了一下）好吧。"

    narrator "她放下手中的笔，站起身，跟着张姐一起走出了办公室。"

    # ============================================================
    # 1.2 助研津贴审核的细节
    # ============================================================
    label ch2_scene1_audit:
        scene bg_office_afternoon with fade

        narrator "下午两点，沈思回到办公室，继续审她的单子。"

        narrator "她拿起上午没审完的第9份单子，开始逐项核对。"

        narrator "这是一份来自化学与材料学院的助研津贴发放表，导师是陈明德教授，发放对象是8名硕士研究生，每人每月2000元，发放周期是2026年3月至7月，共计5个月，总金额80000元。"

        narrator "沈思逐项核对——"
        narrator "发放名单：8名学生，学号、姓名、专业都对得上，学籍状态显示「在读」。"
        narrator "发放标准：每人每月2000元，符合规定。"
        narrator "发放周期：3月至7月，共5个月，符合规定。"
        narrator "签字盖章：陈明德教授的签字清晰可辨，学院公章盖在指定位置。"
        narrator "附件材料：8名学生的银行卡复印件、身份证复印件、助研协议……"

        shen_si "……等等。"

        narrator "沈思皱了皱眉。"

        narrator "附件材料里，除了8名学生的银行卡复印件、身份证复印件、助研协议之外，还夹着一份合同和一张发票。"

        narrator "她把合同抽出来，仔细看了看。"

        narrator "合同标题是《测试服务合同》，甲方（委托方）是「深圳亿纬锂电池有限公司」，乙方（受托方）是「广州市天河区科信测试技术服务中心」。"

        narrator "合同内容大致是：甲方委托乙方对「高性能锂离子电池隔膜材料」进行一系列测试，包括电化学性能测试、热稳定性测试、机械强度测试等，测试费用共计68000元，付款方式为一次性付清。"

        narrator "合同签订日期是2026年5月20日，甲方签字人是「陈明德」，乙方签字人是「王丽」，并盖有乙方的公章。"

        narrator "沈思又拿起那张发票，看了看。"

        narrator "发票是一张增值税普通发票，开票日期是2026年6月5日，购买方是「华南理工大学」，销售方是「广州市天河区科信测试技术服务中心」，货物或应税劳务名称是「测试服务费」，金额是68000元，税率是6%%，税额是4080元，价税合计是72080元。"

        shen_si "……不对。"

        narrator "合同金额是68000元，但发票上的价税合计是72080元。虽然68000元是不含税金额，加上6%%的税率正好是72080元，但问题是——这份测试合同和发票，为什么会夹在助研津贴的报销单里？"

        narrator "助研津贴和测试服务费，完全是两回事。助研津贴是给学生的生活补贴，测试服务费是支付给外部机构的测试费用。这两笔钱，应该分别走不同的报销流程，不应该混在一起。"

        narrator "沈思皱了皱眉，继续往下翻。"

        narrator "在测试合同和发票下面，她还发现了一张发票——金额9600元，名目是「技术咨询费」，收款方同样是「广州市天河区科信测试技术服务中心」，开票日期是2026年6月5日。"

        narrator "沈思的心沉了下去。"

        narrator "这两张发票，一张68000元，一张9600元，加起来一共77600元。收款方都是同一家公司——「广州市天河区科信测试技术服务中心」。"

        narrator "这家公司，她好像从来没听说过。"

        narrator "沈思放下手中的单据，靠在椅背上，闭上眼睛。"

        narrator "她的直觉告诉她——这件事有问题。"
        narrator "但问题出在哪里，她一时还说不上来。"

        narrator "她重新拿起那份测试合同，仔细看了看合同上的每一个细节。"
        narrator "合同甲方是「深圳亿纬锂电池有限公司」，这是陈明德教授横向课题的委托方。合同乙方是「广州市天河区科信测试技术服务中心」，这是一家她从来没听说过的公司。"

        narrator "她拿起手机，打开天眼查APP，输入了这家公司的名字。"

    # ============================================================
    # 1.3 天眼查的发现
    # ============================================================
    label ch2_scene1_tianyancha:
        scene bg_office_afternoon with fade

        narrator "手机屏幕上的天眼查界面加载了几秒钟，然后显示出查询结果。"

        narrator "公司名称：广州市天河区科信测试技术服务中心"
        narrator "统一社会信用代码：91440106MA59J8XXXX"
        narrator "法定代表人：王丽"
        narrator "成立日期：2025年3月15日"
        narrator "注册资本：50万元"
        narrator "注册地址：广州市天河区五山路123号201室"
        narrator "经营范围：材料测试技术服务、技术咨询、技术转让"
        narrator "经营状态：存续"

        narrator "沈思的目光停留在「法定代表人」那一栏——王丽。"

        shen_si "王丽……这个名字有点熟悉。"

        narrator "她想了想，突然记起——陈明德教授的妻子，好像就叫王丽！"

        narrator "她继续往下翻，查看公司的股东信息。"

        narrator "股东信息：王丽，持股比例100%%，认缴出资额50万元。"

        narrator "沈思的心跳开始加速。"

        narrator "王丽持股100%%，是这家公司的唯一股东。而王丽，正是陈明德教授的妻子。"
        narrator "这意味着，陈明德教授的横向课题，通过测试服务合同和技术咨询合同，向自己妻子的公司支付了77600元。"

        narrator "这不是典型的利益输送吗？"

        $ ch2_tianyancha_checked = True

        narrator "沈思继续查看公司的更多信息。"

        narrator "主要人员——王丽，执行董事兼经理；李明，监事。"

        narrator "变更记录——"
        narrator "2025年3月15日，公司成立。"
        narrator "2025年5月20日，经营范围变更，增加「材料测试技术服务」。"
        narrator "2026年1月10日，注册地址变更，从「广州市天河区黄埔大道西100号」变更为「广州市天河区五山路123号201室」。"

        narrator "沈思注意到，公司成立的时间是2025年3月，而陈明德教授的深圳亿纬横向课题（课题号：2026-HX-0047）是2026年才立项的。"
        narrator "但公司成立后不久，经营范围就增加了「材料测试技术服务」，注册地址也变更到了华南理工大学附近。"

        narrator "这一切，看起来都像是为陈明德教授的横向课题「量身定制」的。"

        narrator "沈思深吸一口气，继续查看公司的财务信息。"

        narrator "年报信息（2025年度）——"
        narrator "资产总额：12.5万元"
        narrator "负债总额：8.3万元"
        narrator "营业收入：0元"
        narrator "净利润：-3.2万元"

        narrator "沈思皱了皱眉。"

        narrator "2025年度，这家公司的营业收入是0元，净利润是-3.2万元。这说明，公司在2025年一整年，没有接到任何业务，完全处于亏损状态。"

        narrator "但2026年6月，这家公司突然接到了陈明德教授横向课题的测试服务合同，金额68000元，还有技术咨询费9600元，合计77600元。"

        narrator "这77600元，几乎相当于这家公司2025年度资产总额的6倍多。"

        narrator "沈思的心里，已经有了一个初步的判断——这家公司，很可能就是陈明德教授为了套取科研经费而设立的「空壳公司」。"

        narrator "但她还需要更多的证据。"

        narrator "她放下手机，重新拿起那份测试合同，仔细看了看合同上的测试内容。"

        narrator "合同上列出的测试项目包括：电化学性能测试、热稳定性测试、机械强度测试、微观结构表征……"

        narrator "这些测试项目，看起来都很专业。但问题是——陈明德教授的课题组，自己就有这些测试设备，为什么要花68000元送到外面去测试？"

        narrator "沈思想起，化学与材料学院有一个「材料表征中心」，里面配备了各种先进的测试设备，不仅对本院师生开放，还对全校师生开放，使用费用相对较低。"

        narrator "如果陈明德教授真的需要做这些测试，完全可以使用学院的设备，为什么要花68000元送到外面去？"

        narrator "除非……这些测试根本就没做，68000元只是通过合同的形式，把钱从课题经费里套出来，转入他妻子的公司。"

        narrator "沈思的手指在桌面上轻轻敲击着，节奏很慢。这是她思考时的习惯动作。"

        narrator "她需要核实几件事——"
        narrator "第一，这家公司到底有没有实际的办公地点和测试设备？"
        narrator "第二，陈明德教授的课题组，最近是否真的送样品出去做过测试？"
        narrator "第三，这笔77600元的费用，在财务系统里是怎么记录的？"

        narrator "她决定，先从第三件事开始查起。"

    # ============================================================
    # 1.4 财务系统的查询
    # ============================================================
    label ch2_scene1_finance:
        scene bg_office_afternoon with fade

        narrator "沈思打开电脑，登录了学校的财务管理系统。"

        narrator "这个系统她用过无数次——每年审核报销时，都要在这里核对课题余额和报销记录。但今天，她要查的不是普通的报销，而是一份可能涉及违规的测试服务合同。"

        narrator "她输入陈明德教授的工号，点击「课题经费查询」。"

        narrator "屏幕上弹出一串列表，全是陈教授名下的课题——"
        narrator "2024-HX-0022：国家自然科学基金（面上项目），余额¥127,450"
        narrator "2025-HX-0089：国家重点研发计划，参与课题，余额¥89,300"
        narrator "2026-HX-0047：深圳亿纬横向课题，余额¥523,000"

        narrator "沈思点击了「2026-HX-0047」，查看该课题的报销明细。"

        narrator "屏幕上列出了一长串记录——"

        narrator "3月15日，试剂耗材采购，¥32,000，已核销，经手人：张文浩。"
        narrator "4月2日，差旅费（上海会议），¥8,500，已核销，经手人：张文浩。"
        narrator "4月20日，设备维修费，¥15,000，已核销，经手人：张文浩。"
        narrator "5月10日，论文版面费（3篇），¥12,000，已核销，经手人：张文浩。"
        narrator "6月8日，测试服务费，¥68,000，待审核，经手人：陈明德。"
        narrator "6月8日，技术咨询费，¥9,600，待审核，经手人：陈明德。"

        $ ch2_finance_checked = True

        narrator "沈思的眼睛盯着最后两行。"

        narrator "测试服务费68000元，技术咨询费9600元——加起来正好77600元。收款方都是同一家公司——「广州市天河区科信测试技术服务中心」。"

        narrator "而且，这两笔费用的经手人，不再是之前的「张文浩」，而是变成了「陈明德」本人。"

        narrator "张文浩……这个名字沈思有点印象。他是陈明德教授的科研助理，负责管理课题组的所有财务报销。但上个月，他突然辞职了，据说是「个人原因」。"

        $ ch2_zhang_wenhao_resigned = True

